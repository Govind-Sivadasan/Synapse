# Synapse Environment Configuration
# Copy to .env and adjust as needed

# Application
APP_NAME=Synapse
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
TEMP_STORAGE_PATH=/data/temp_dicom
AUTH_CONFIG_ENCRYPTION_KEY=change-me-32-byte-key-for-aes!!

# DIMSE Listener
DIMSE_AE_TITLE=SYNAPSE
DIMSE_PORT=11112
DIMSE_PROMISCUOUS_MODE=false

# Database
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse_secret
POSTGRES_DB=synapse
DATABASE_URL=postgresql+asyncpg://synapse:synapse_secret@postgres:5432/synapse

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_ROUTING_CONCURRENCY=4
CELERY_MIGRATION_CONCURRENCY=8
CELERY_MAX_RETRIES=3

# Performance tuning (Phase 1)
DICOMWEB_HTTP_MAX_CONNECTIONS=20
DICOMWEB_HTTP_MAX_KEEPALIVE=10
DASHBOARD_METRICS_CACHE_TTL_SECONDS=30
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
METRICS_ENABLED=true

# Performance tuning (Phase 2)
WADO_PARALLEL_INSTANCES=8
MIGRATION_QUEUE_BACKPRESSURE_MAX=200
ROUTING_QUEUE_BACKPRESSURE_MAX=200
ROUTING_BACKPRESSURE_DIMSE_REFUSE=true
MIGRATION_STREAMING_DISCOVERY=false
MIGRATION_COORDINATOR_PAGE_SIZE=100
MIGRATION_COORDINATOR_CHAIN_DELAY_SECONDS=0
MIGRATION_PREFLIGHT_ECHO=true
MIGRATION_SINGLE_ACTIVE_JOB=true
MIGRATION_REDIS_COUNTERS_ENABLED=true
MIGRATION_JOB_COUNTER_FLUSH_INTERVAL=5

# Performance tuning (Phase 3)
PARTITION_MONTHS_AHEAD=3
PARTITION_MAINTENANCE_INTERVAL_SECONDS=86400
PARTITION_RETENTION_ENABLED=true

# WebSocket ops (Phase 3.3)
WS_EVENT_BATCH_INTERVAL_MS=250
WS_EVENT_BATCH_MAX_SIZE=50
WS_OPS_SNAPSHOT_INTERVAL_SECONDS=5
WS_OPS_EVENTS_ENABLED=true

# STOW tuning
STOW_BATCH_SIZE=4
STOW_PARALLEL_BATCHES=2

# STOW rate limits (Phase 4.5 — per destination DICOMweb URL)
STOW_RATE_LIMIT_ENABLED=false
STOW_DESTINATION_RATE_PER_SECOND=8
STOW_DESTINATION_RATE_BURST=16
STOW_RATE_LIMIT_POLL_SECONDS=0.05

# OpenTelemetry (optional — set OTEL_ENABLED=true and point at your collector)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=synapse-backend
OTEL_EXPORTER_ENDPOINT=http://otel-collector:4318/v1/traces

# Keycloak
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=synapse
KEYCLOAK_CLIENT_ID=synapse-ui
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Ollama (Chatbot)
OLLAMA_BASE_URL=http://ollama:11434
# 3b (~2 GB) recommended for 8 GB RAM; use qwen2.5:7b-instruct (~4.7 GB) if you have 16 GB+
OLLAMA_MODEL=qwen2.5:7b-instruct

# Orthanc (internal Docker network)
ORTHANC_ONPREM_DICOMWEB_URL=http://orthanc-onprem:8042/dicom-web
ORTHANC_CLOUD_DICOMWEB_URL=http://orthanc-cloud:8042/dicom-web

# Frontend (build-time)
VITE_API_BASE_URL=http://localhost:8000
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=synapse
VITE_KEYCLOAK_CLIENT_ID=synapse-ui
VITE_WS_URL=ws://localhost:8000/ws/events
