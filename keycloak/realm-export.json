{
  "realm": "synapse",
  "enabled": true,
  "displayName": "Synapse DICOM Router",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full system administration access"
      },
      {
        "name": "operator",
        "description": "Migration job control and health monitoring"
      },
      {
        "name": "service_user",
        "description": "Routing monitor, audit logs, and chatbot access"
      },
      {
        "name": "viewer",
        "description": "Read-only dashboard and reports"
      }
    ]
  },
  "clients": [
    {
      "clientId": "synapse-ui",
      "name": "Synapse Frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5173",
        "+"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/*"
      }
    },
    {
      "clientId": "synapse-api",
      "name": "Synapse Backend API",
      "enabled": true,
      "publicClient": false,
      "secret": "synapse-api-secret",
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@synapse.local",
      "firstName": "Synapse",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["admin", "operator", "service_user", "viewer"]
    },
    {
      "username": "operator",
      "enabled": true,
      "email": "operator@synapse.local",
      "firstName": "Synapse",
      "lastName": "Operator",
      "credentials": [
        {
          "type": "password",
          "value": "operator123",
          "temporary": false
        }
      ],
      "realmRoles": ["operator", "service_user", "viewer"]
    },
    {
      "username": "service",
      "enabled": true,
      "email": "service@synapse.local",
      "firstName": "Synapse",
      "lastName": "Service",
      "credentials": [
        {
          "type": "password",
          "value": "service123",
          "temporary": false
        }
      ],
      "realmRoles": ["service_user", "viewer"]
    },
    {
      "username": "viewer",
      "enabled": true,
      "email": "viewer@synapse.local",
      "firstName": "Synapse",
      "lastName": "Viewer",
      "credentials": [
        {
          "type": "password",
          "value": "viewer123",
          "temporary": false
        }
      ],
      "realmRoles": ["viewer"]
    }
  ]
}
