# Used by `npm run dev` (Vite development server).
# API and WebSocket requests are proxied to the backend — see vite.config.ts.
# Keycloak stays on localhost:8080 (already allowed in realm-export.json).

VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=synapse
VITE_KEYCLOAK_CLIENT_ID=synapse-ui
